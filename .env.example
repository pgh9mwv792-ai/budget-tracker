# Copy this file to .env and fill in real values.
# These VITE_ variables are bundled into the frontend JS, so only ever put
# PUBLIC/safe keys here (never a Plaid secret or a Supabase service-role key).

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-public-key

# ---------------------------------------------------------------------------
# Everything below this line is NOT read by the frontend. These are set as
# secrets on the Supabase project (Edge Function secrets), not in this file.
# Listed here just so you know what to go create:
#
#   supabase secrets set PLAID_CLIENT_ID=xxx
#   supabase secrets set PLAID_SECRET=xxx
#   supabase secrets set PLAID_ENV=sandbox
#
# For the AI assistant (the chat bubble), set your Anthropic API key:
#
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
#   # optional — override the model (defaults to a current Claude Sonnet):
#   supabase secrets set ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
#   # optional — max assistant requests per user per day (defaults to 100).
#   # Each Claude call counts; one chat message can use several when tools run.
#   supabase secrets set AI_DAILY_LIMIT=100
#
# Note: SUPABASE_URL, SUPABASE_ANON_KEY, and SUPABASE_SERVICE_ROLE_KEY are
# injected into Edge Functions automatically by Supabase — you don't need
# to set those as secrets yourself.
# ---------------------------------------------------------------------------
